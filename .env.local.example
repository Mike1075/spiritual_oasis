# 飞书留资写表（高考直播线索）——复制为 .env.local 并填入 APP_SECRET；Vercel 上配到环境变量
# 只有 FEISHU_APP_SECRET 是机密，必须配置；其余有内置默认值，一般不用改。

# 飞书应用 App Secret（在飞书开放平台 > 凭证与基础信息 获取）
FEISHU_APP_SECRET=

# 以下均有默认值，仅在换应用/换表时才需覆盖：
# FEISHU_APP_ID=cli_aa948c518565dcba
# FEISHU_BITABLE_APP_TOKEN=BMlcbTjznaJL5WsOXsxcgHavnrh   # base「心灵家园·高考直播线索」
# FEISHU_BITABLE_TABLE_ID=tblWYdnuPsa86tTp               # 表「高考直播线索」
# base 链接：https://wcntmlbovrgg.feishu.cn/base/BMlcbTjznaJL5WsOXsxcgHavnrh
# 注意：该应用需被加为此 base 协作者(edit)，否则写表 91403 Forbidden（已配置）。
# FEISHU_LOCK_APP_TOKEN=IrGKbwczXa33ZRsC104cM8WsnKs       # 私密 base「618锁位表·私密」（应用自有）
# FEISHU_LOCK_TABLE_ID=tbll5i7M32yTQK88                   # 表「618锁位表」

# Supabase（redesign 分支新增）
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 由 Mike 在本地/Vercel 配置，勿入库
SUPABASE_SERVICE_ROLE_KEY=
